# =============================================================================
# NEXUS TLS — FastAPI Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before starting the server.
#
# MULTI-MACHINE SETUP:
#   This file is for the SERVER machine that runs the FastAPI backend.
#   The client machines (running apps/web) need to point RISK_API_URL
#   to this server's IP address — see apps/web/.env.example for details.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Option A (default, no setup needed): leave DATABASE_URL blank → uses SQLite
# Option B (production): set a PostgreSQL URL below
DATABASE_URL=
# DATABASE_URL=postgresql+asyncpg://postgres:devpassword@localhost:5432/nexus_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
# Option A (no Redis, sessions stored in-process):  leave blank
# Option B (local Redis):  redis://default:devpassword@localhost:6379
# Option C (Upstash cloud): rediss://default:<password>@<host>:6379
REDIS_URL=

# ── Auth ──────────────────────────────────────────────────────────────────────
# MUST exactly match NEXTAUTH_SECRET in apps/web/.env
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=92b0c3f5a89e4c1d76ea2f9b87c65d4e1f3a2b5c8e7d9b0a1c3e5f7a9d2b4c6e

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=gY4P7-J_9k0vTzX1wQ6L8bA2rO5eD4mC3uN9fH1yS0o=

# ── CORS ──────────────────────────────────────────────────────────────────────
# ADD THE IP/URL OF EVERY CLIENT MACHINE that will access this server.
# Format: JSON array of origins.
# Example (two client machines on LAN):
#   CORS_ORIGINS=["http://192.168.1.20:3000","http://192.168.1.21:3000"]
# Example (single localhost dev):
#   CORS_ORIGINS=["http://localhost:3000"]
CORS_ORIGINS=["http://localhost:3000"]

# ── Geo Services (Optional) ───────────────────────────────────────────────────
# Leave blank to use fallback (0.0 lat/lon, no threat scores)
GEOIP2_DB_PATH=
ABUSEIPDB_API_KEY=

# ── OpenTelemetry (Optional) ──────────────────────────────────────────────────
# Leave blank to disable tracing
OTEL_ENDPOINT=
